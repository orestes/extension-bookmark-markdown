{
  "manifest_version": 3,
  "name": "Bookmark as Markdown",
  "version": "1.3.0",
  "description": "Save any webpage as a Markdown file with YAML front matter. Download directly (default) or send to your own server.",
  "permissions": ["activeTab", "offscreen", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/disabled-16.png",
      "32": "icons/disabled-32.png",
      "48": "icons/disabled-48.png",
      "128": "icons/disabled-128.png"
    }
  }
}

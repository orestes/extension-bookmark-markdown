{
  "name": "extension-bookmark-markdown",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && node build.mjs",
    "format:check": "prettier --check .",
    "release": "node build.mjs && node release.mjs",
    "hooks:install": "husky"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "choices.js": "^11.2.1",
    "turndown": "^7.2.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/chrome": "^0.1.38",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2"
  },
  "packageManager": "yarn@4.13.0",
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}

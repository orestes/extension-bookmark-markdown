{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/npm", { "npmPublish": false }],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/bump-manifest.mjs ${nextRelease.version} && yarn build && node release.mjs"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "src/manifest.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release/bookmark-as-markdown-*.zip",
            "label": "Chrome Extension (ZIP)"
          }
        ]
      }
    ],
    [
      "@semantic-release/exec",
      {
        "publishCmd": "npx chrome-webstore-upload-cli@3 upload --source release/bookmark-as-markdown-${nextRelease.version}.zip"
      }
    ]
  ]
}
